# Enforce Unix line endings for shell scripts (critical for Docker on Windows)
docker/entrypoint.sh text eol=lf
*.sh text eol=lf

# Blade / PHP / JS / CSS – normalize line endings
*.php text eol=lf
*.blade.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.env* text eol=lf

# Binary files – do not touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.phar binary
