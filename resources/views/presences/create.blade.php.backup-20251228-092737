<script>
    // Configuration
    const officeLat = -6.3623194;
    const officeLon = 106.6476751;
    const thresholdMeters = 1000; // Radius 1000 meter sesuai server
    const threshold = thresholdMeters / 111320; // Konversi ke derajat decimal (rata-rata)
    const allowedSSIDs = ['UNPAM VIKTOR', 'Serhan 2', 'Serhan', 'S53s'];

    // DOM Elements
    const workTypeRadios = document.querySelectorAll('input[name="work_type"]');
    const gpsSection = document.getElementById('gps-section');
    const latitudeInput = document.getElementById('latitude');
    const longitudeInput = document.getElementById('longitude');
    const accuracyInput = document.getElementById('accuracy');
    const fingerprintInput = document.getElementById('fingerprint');
    const isMobileInput = document.getElementById('is_mobile');
    const ssidInput = document.getElementById('ssid');
    const mapsIframe = document.getElementById('maps-iframe');
    const btnPresent = document.getElementById('btn-present');
    const faceContainer = document.getElementById('face-liveness-container');
    const livenessStatus = document.getElementById('liveness-status');
    const video = document.getElementById('video');

    // State
    let isFingerprintReady = false;
    let isLivenessVerified = false;
    let gpsRequestInProgress = false;
    let gpsLastError = null;
    let gpsRequestId = 0;
    let gpsWatchdog = null;

    // 0. Debug Logger for Mobile
    function logToUI(msg, type = 'info') {
        const debugContent = document.getElementById('debug-content');
        if (!debugContent) return;
        const color = type === 'error' ? '#ff6b6b' : (type === 'success' ? '#51cf66' : '#ffffff');
        const time = new Date().toLocaleTimeString();
        debugContent.innerHTML += `<div style="font-size:9px; color: ${color}">[${time}] ${msg}</div>`;
        debugContent.scrollTop = debugContent.scrollHeight;
        console.log(`[PresenceDebug] ${msg}`);
    }

    // 1. Initialize FingerprintJS
    async function initFingerprint() {
        logToUI("Loading FingerprintJS...");
        try {
            if (typeof FingerprintJS === 'undefined') {
                logToUI("FingerprintJS library not loaded!", 'error');
                return;
            }
            const fp = await FingerprintJS.load();
            const result = await fp.get();
            fingerprintInput.value = result.visitorId;
            logToUI(`Fingerprint Ready: ${result.visitorId}`, 'success');
            
            // Simple Mobile Detection
            const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
            isMobileInput.value = isMobile ? '1' : '0';
            logToUI(`Device: ${isMobile ? 'Mobile' : 'Desktop'}`);
            
            isFingerprintReady = true;
            checkReadyState();
        } catch (err) {
            logToUI(`FingerprintJS Error: ${err.message}`, 'error');
        }
    }

    // 2. Face Liveness Detection
    async function initFaceLiveness() {
        logToUI("Initializing Face AI...");
        faceContainer.style.display = 'block';
        livenessStatus.innerHTML = '<span class="badge bg-warning">Memuat AI Model...</span>';
        
        try {
            if (typeof faceapi === 'undefined') {
                logToUI("face-api.js library not loaded!", 'error');
                return;
            }
            const MODEL_URL = '{{ asset('vendor/face-api/weights') }}';
            await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
            logToUI("Face AI Models Loaded", 'success');
            
            logToUI("Requesting Camera Access...");
            const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" } });
            video.srcObject = stream;
            
            livenessStatus.innerHTML = '<span class="badge bg-info">Menunggu pergerakan wajah...</span>';
            
            video.onplay = () => {
                logToUI("Camera Stream Active");
                let detectionCount = 0;
                const interval = setInterval(async () => {
                    const detections = await faceapi.detectAllFaces(video, new faceapi.TinyFaceDetectorOptions());
                    if (detections.length > 0) {
                        detectionCount++;
                        if (detectionCount % 5 === 0) logToUI(`Face detected (${detectionCount}/10)...`);
                        if (detectionCount >= 10) { 
                            isLivenessVerified = true;
                            livenessStatus.innerHTML = '<span class="badge bg-success">✓ Identitas Wajah Terverifikasi</span>';
                            logToUI("Face Liveness Verified", 'success');
                            clearInterval(interval);
                            checkReadyState();
                        }
                    }
                }, 500);
            };

        } catch (err) {
            logToUI(`Face AI Error: ${err.message}`, 'error');
            livenessStatus.innerHTML = '<span class="badge bg-danger">Kamera gagal / AI error.</span>';
        }
    }

    function checkReadyState() {
        const workType = Array.from(workTypeRadios).find(r => r.checked)?.value;
        const isWFO = workType === 'WFO';
        
        // Update Fingerprint Check (ALWAYS required for ALL modes)
        updateCheckItem('check-fingerprint', isFingerprintReady);
        
        if (isWFO) {
            // WFO Mode: 4 validations (Fingerprint + GPS + WiFi + Face)
            document.getElementById('wfo-checks').style.display = 'block';
            
            // Location Check
            const lat = parseFloat(latitudeInput.value);
            const lon = parseFloat(longitudeInput.value);
            let isLocationOK = false;
            
            const locationAlert = document.getElementById('location-warning');
            
            if (!isNaN(lat) && !isNaN(lon)) {
                const distDegrees = Math.sqrt(Math.pow(lat - officeLat, 2) + Math.pow(lon - officeLon, 2));
                const distMeters = Math.round(distDegrees * 111320);
                
                // Update Distance Display
                const distDisplay = document.getElementById('distance-display');
                if (distDisplay) distDisplay.value = distMeters;
                
                // Hide warning alert when coordinates are available (permission granted)
                if (locationAlert) locationAlert.classList.add('d-none');
                
                if (distMeters <= thresholdMeters) {
                    isLocationOK = true;
                    logToUI(`Location OK: ${distMeters}m from office`, 'success');
                } else {
                    logToUI(`Location: Outside radius (${distMeters}m > ${thresholdMeters}m)`, 'error');
                }
            } else {
                // No valid coordinates yet (WFO)
                if (locationAlert) {
                    locationAlert.classList.remove('d-none');
                    if (gpsRequestInProgress) {
                        locationAlert.innerHTML = '<b>Note</b> : Mengambil lokasi... pastikan GPS aktif dan tunggu beberapa detik, lalu klik <b>Ambil Lokasi</b> jika belum terbaca.';
                    } else if (gpsLastError) {
                        locationAlert.innerHTML = '<b>Note</b> : ' + gpsLastError;
                    } else {
                        locationAlert.innerHTML = '<b>Note</b> : Mohon izinkan akses lokasi, supaya presensi diterima.';
                    }
                }
            }
            
            updateCheckItem('check-location', isLocationOK);
            
            // WiFi Check (WFO only)
            const currentSSID = ssidInput.value.trim();
            const isWiFiOK = allowedSSIDs.includes(currentSSID);
            updateCheckItem('check-wifi', isWiFiOK);
            
            // Face Check (WFO)
            updateCheckItem('check-face', isLivenessVerified);
            
            // Enable button ONLY if ALL 4 conditions met for WFO
            const allConditionsMet = isFingerprintReady && isLocationOK && isWiFiOK && isLivenessVerified;
            
            logToUI(`WFO Button State: FP=${isFingerprintReady}, Loc=${isLocationOK}, WiFi=${isWiFiOK}, Face=${isLivenessVerified} => ${allConditionsMet ? 'ENABLED' : 'DISABLED'}`);
            
            if (allConditionsMet) {
                btnPresent.removeAttribute('disabled');
            } else {
                btnPresent.setAttribute('disabled', 'disabled');
            }
        } else {
            // WFH/WFA Mode: 2 validations (Fingerprint + Face)
            // Hide WFO-specific checks
            document.getElementById('wfo-checks').style.display = 'none';
            
            // Check both Fingerprint AND Face for WFH/WFA
            const bothReady = isFingerprintReady && isLivenessVerified;
            
            logToUI(`${workType} Check: FP=${isFingerprintReady}, Face=${isLivenessVerified} => ${bothReady ? 'ENABLED' : 'DISABLED'}`);
            
            if (bothReady) {
                btnPresent.removeAttribute('disabled');
                logToUI(`Button ENABLED (${workType})`, 'success');
            } else {
                btnPresent.setAttribute('disabled', 'disabled');
                if (!isFingerprintReady) {
                    logToUI("Waiting for fingerprint...");
                } else if (!isLivenessVerified) {
                    logToUI("Waiting for face verification...");
                }
            }
        }
    }

    function updateCheckItem(id, isSuccess) {
        const el = document.getElementById(id);
        if (!el) return;
        const icon = el.querySelector('i');
        if (isSuccess) {
            el.classList.add('text-success');
            el.classList.remove('text-muted');
            icon.className = 'bi bi-check-circle-fill text-success';
        } else {
            el.classList.remove('text-success');
            icon.className = 'bi bi-clock text-warning';
        }
    }

    // Toggle GPS section based on work type
    workTypeRadios.forEach(radio => {
        radio.addEventListener('change', function() {
            const isWFO = this.value === 'WFO';
            
            if (isWFO) {
                // WFO: Show GPS section, start GPS and Face
                gpsSection.style.display = 'block';
                logToUI("WFO Mode: 4 validations (Fingerprint + GPS + WiFi + Face)");
                getGPSLocation();
                
                // Start face if not already started
                if (!isLivenessVerified) {
                    initFaceLiveness();
                }
            } else {
                // WFH/WFA: Hide GPS section, but KEEP Face detection
                gpsSection.style.display = 'none';
                logToUI(`${this.value} Mode: 2 validations (Fingerprint + Face)`);
                
                // Clear GPS data (not needed for WFH/WFA)
                latitudeInput.value = '';
                longitudeInput.value = '';
                accuracyInput.value = '';
                
                // Hide location alert
                const locationAlert = document.getElementById('location-warning');
                if (locationAlert) locationAlert.classList.add('d-none');
                
                // Start face detection if not already started
                if (!isLivenessVerified && faceContainer.style.display !== 'block') {
                    logToUI("Starting face verification for WFH/WFA...");
                    initFaceLiveness();
                }
            }
            
            // Re-check ready state
            checkReadyState();
        });
    });

    ssidInput.addEventListener('change', checkReadyState);

    function getGPSLocation() {
        // Start a new request and invalidate any previous in-flight results
        const requestId = ++gpsRequestId;
        gpsRequestInProgress = true;
        gpsLastError = null;

        if (gpsWatchdog) {
            clearTimeout(gpsWatchdog);
            gpsWatchdog = null;
        }

        logToUI('Starting GPS Search...');
        checkReadyState();

        // Safety watchdog in case the browser never calls success/error
        gpsWatchdog = setTimeout(() => {
            if (requestId !== gpsRequestId) return;
            gpsRequestInProgress = false;
            gpsLastError = 'Gagal mengambil lokasi: Timeout. Coba lagi dan pastikan GPS/Layanan Lokasi aktif.';
            logToUI(gpsLastError, 'error');
            checkReadyState();
        }, 35000);

        // Geolocation requires a secure context (HTTPS or localhost)
        if (typeof window !== 'undefined' && window.isSecureContext === false) {
            if (requestId !== gpsRequestId) return;
            gpsRequestInProgress = false;
            gpsLastError = 'Lokasi hanya bisa digunakan di HTTPS (SSL). Silakan akses via HTTPS/PWA yang terpasang dari HTTPS.';
            logToUI('GPS blocked: not a secure context (HTTPS required).', 'error');
            if (gpsWatchdog) { clearTimeout(gpsWatchdog); gpsWatchdog = null; }
            checkReadyState();
            return;
        }

        if (!navigator.geolocation) {
            if (requestId !== gpsRequestId) return;
            gpsRequestInProgress = false;
            gpsLastError = 'Browser Anda tidak mendukung Geolocation.';
            logToUI('Geolocation not supported!', 'error');
            if (gpsWatchdog) { clearTimeout(gpsWatchdog); gpsWatchdog = null; }
            checkReadyState();
            return;
        }

        updateCheckItem('check-location', false);

        const onSuccess = (position) => {
            if (requestId !== gpsRequestId) return;
            gpsRequestInProgress = false;
            if (gpsWatchdog) { clearTimeout(gpsWatchdog); gpsWatchdog = null; }

            const lat = position.coords.latitude;
            const lon = position.coords.longitude;
            const acc = position.coords.accuracy;
            logToUI(`GPS Hooked: ${lat.toFixed(5)}, ${lon.toFixed(5)} (Acc: ${acc}m)`);

            latitudeInput.value = lat;
            longitudeInput.value = lon;
            accuracyInput.value = acc;

            // Anti-mock: extremely perfect accuracy
            if (acc <= 1) {
                logToUI('Suspicious GPS Accuracy detected!', 'error');
                alert('Akurasi GPS mencurigakan. Jangan gunakan Fake GPS.');
            }

            if (mapsIframe) {
                mapsIframe.src = `https://maps.google.com/maps?q=${lat},${lon}&hl=en&z=14&output=embed`;
            }

            const distDegrees = Math.sqrt(Math.pow(lat - officeLat, 2) + Math.pow(lon - officeLon, 2));
            const distMeters = Math.round(distDegrees * 111320);
            logToUI(`Distance to Office: ${distMeters} meter`);

            checkReadyState();
        };

        const onErrorFinal = (error) => {
            if (requestId !== gpsRequestId) return;
            gpsRequestInProgress = false;
            if (gpsWatchdog) { clearTimeout(gpsWatchdog); gpsWatchdog = null; }

            let msg = 'Gagal mengambil lokasi: ';
            switch (error.code) {
                case error.PERMISSION_DENIED:
                    msg += 'Izin lokasi ditolak. Aktifkan izin lokasi untuk situs ini (Site settings → Location → Allow).';
                    break;
                case error.POSITION_UNAVAILABLE:
                    msg += 'Lokasi tidak tersedia. Pastikan GPS/Layanan Lokasi aktif.';
                    break;
                case error.TIMEOUT:
                    msg += 'Timeout. Coba lagi dan pastikan sinyal GPS bagus (keluar ruangan jika perlu).';
                    break;
                default:
                    msg += 'Unknown error.';
                    break;
            }

            gpsLastError = msg;
            logToUI(msg, 'error');
            checkReadyState();
        };

        try {
            // Try high accuracy first; if it times out/unavailable, retry once with low accuracy
            navigator.geolocation.getCurrentPosition(
                onSuccess,
                (error) => {
                    if (requestId !== gpsRequestId) return;
                    if (error.code === error.TIMEOUT || error.code === error.POSITION_UNAVAILABLE) {
                        logToUI('High accuracy GPS failed, retrying with low accuracy...', 'error');
                        navigator.geolocation.getCurrentPosition(
                            onSuccess,
                            onErrorFinal,
                            { enableHighAccuracy: false, timeout: 30000, maximumAge: 15000 }
                        );
                        return;
                    }
                    onErrorFinal(error);
                },
                { enableHighAccuracy: true, timeout: 30000, maximumAge: 0 }
            );
        } catch (e) {
            if (requestId !== gpsRequestId) return;
            gpsRequestInProgress = false;
            if (gpsWatchdog) { clearTimeout(gpsWatchdog); gpsWatchdog = null; }
            gpsLastError = 'Gagal mengambil lokasi: ' + (e && e.message ? e.message : 'Unknown exception');
            logToUI(gpsLastError, 'error');
            checkReadyState();
        }
    }

    // Initialize on load
    document.addEventListener('DOMContentLoaded', () => {
        logToUI("System initialized");
        
        // Initialize fingerprint for all modes
        initFingerprint();
        
        // Check which work type is selected
        const selectedWorkType = Array.from(workTypeRadios).find(r => r.checked)?.value || 'WFO';
        
        if (selectedWorkType === 'WFO') {
            // WFO mode: Show GPS section, start GPS and Face
            gpsSection.style.display = 'block';
            logToUI("WFO Mode (default): 4 validations (Fingerprint + GPS + WiFi + Face)");
            getGPSLocation();
            initFaceLiveness();
        } else {
            // WFH/WFA mode: Hide GPS section, but START Face detection
            gpsSection.style.display = 'none';
            logToUI(`${selectedWorkType} Mode (default): 2 validations (Fingerprint + Face)`);
            
            // Make sure alert is hidden
            const locationAlert = document.getElementById('location-warning');
            if (locationAlert) locationAlert.classList.add('d-none');
            
            // Start face detection for WFH/WFA
            logToUI("Starting face verification for WFH/WFA...");
            initFaceLiveness();
        }
    });

</script>

@endsection