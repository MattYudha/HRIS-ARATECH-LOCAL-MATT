<script>
    // Configuration
    const officeLat = {{ config('presence.office_latitude', -6.3623194) }};
    const officeLon = {{ config('presence.office_longitude', 106.6476751) }};
    const thresholdMeters = {{ config('presence.location_radius', 1000) }};

    // Update current time
    function updateCurrentTime() {
        const now = new Date();
        document.getElementById('current-time').textContent = now.toLocaleTimeString();
    }
    setInterval(updateCurrentTime, 1000);
    updateCurrentTime();

    // Check if WFO mode
    const workType = '{{ $presence->work_type ?? "WFO" }}';
    if (workType === 'WFO') {
        document.getElementById('gps-section').style.display = 'block';
    } else {
        document.getElementById('gps-section').style.display = 'none';
    }

    function getGPSLocation() {
        if (!navigator.geolocation) {
            alert('Browser Anda tidak mendukung Geolocation.');
            return;
        }

        navigator.geolocation.getCurrentPosition(
            function(position) {
                const lat = position.coords.latitude;
                const lon = position.coords.longitude;
                const acc = position.coords.accuracy;

                document.getElementById('latitude').value = lat;
                document.getElementById('longitude').value = lon;
                document.getElementById('accuracy').value = acc;

                // Calculate distance
                const distance = calculateDistance(lat, lon, officeLat, officeLon);
                document.getElementById('distance-display').value = Math.round(distance);

                // Hide warning if location is available
                document.getElementById('location-warning').classList.add('d-none');
            },
            function(error) {
                let msg = 'Gagal mengambil lokasi: ';
                switch (error.code) {
                    case error.PERMISSION_DENIED:
                        msg += 'Izin lokasi ditolak.';
                        break;
                    case error.POSITION_UNAVAILABLE:
                        msg += 'Lokasi tidak tersedia.';
                        break;
                    case error.TIMEOUT:
                        msg += 'Timeout.';
                        break;
                }
                alert(msg);
            },
            { enableHighAccuracy: true, timeout: 30000 }
        );
    }

    function calculateDistance(lat1, lon1, lat2, lon2) {
        const R = 6371000; // Earth radius in meters
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLon = (lon2 - lon1) * Math.PI / 180;
        const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                  Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                  Math.sin(dLon / 2) * Math.sin(dLon / 2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        return R * c;
    }

    // Auto-get location on load if WFO
    document.addEventListener('DOMContentLoaded', function() {
        getGPSLocation();
    });
</script>

