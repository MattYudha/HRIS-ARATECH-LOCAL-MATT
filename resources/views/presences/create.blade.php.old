<!-- Syarat Kelengkapan Presence Checklist (Visual Debug) -->
                    <div id="check-list-section" class="card bg-light mb-3">
                        <div class="card-body p-3">
                            <h6 class="card-title mb-2"><i class="bi bi-shield-check"></i> Syarat Kelengkapan Presence</h6>
                            <ul class="list-group list-group-flush small" id="checklist-items">
