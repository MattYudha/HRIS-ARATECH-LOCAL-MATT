                                    </li>
                                </div>
                            </ul>
                        </div>
                    </div>

                    <!-- Debug Status Log (Hidden by default, used for mobile debugging) -->
                    <div id="debug-log-section" class="card bg-dark text-white mb-3" style="font-family: monospace; font-size: 10px; max-height: 150px; overflow-y: auto;">
                        <div class="card-header py-1 px-2 border-bottom border-secondary d-flex justify-content-between">
                            <span>Monitor Aktivitas (Debug)</span>
                            <span onclick="document.getElementById('debug-content').innerHTML = ''" style="cursor:pointer;">[Clear]</span>
                        </div>
                        <div class="card-body p-2" id="debug-content">
                            <div>System initialized... waiting for actions.</div>
                        </div>
                    </div>

                    <!-- Hidden Security Inputs -->
                    <input type="hidden" name="accuracy" id="accuracy">
                    <input type="hidden" name="fingerprint" id="fingerprint">
                    <input type="hidden" name="is_mobile" id="is_mobile">

                    <!-- Submit Button -->
                    <button type="submit" id="btn-present" class="btn btn-primary" disabled>Present</button>
                </form>

                @endif


            </div>
        </div>
    </section>
</div>

<!-- Security Libraries -->
<script src="{{ asset('vendor/fingerprintjs/fp.min.js') }}"></script>
<script src="{{ asset('vendor/face-api/face-api.min.js') }}"></script>

<script>
    // Configuration
    const officeLat = -6.3623194;
    const officeLon = 106.6476751;
    const thresholdMeters = 1000;
    const allowedSSIDs = ['UNPAM VIKTOR', 'Serhan 2', 'Serhan', 'S53s'];

    // DOM Elements
    const workTypeRadios = document.querySelectorAll('input[name="work_type"]');
    const gpsSection = document.getElementById('gps-section');
    const latitudeInput = document.getElementById('latitude');
    const longitudeInput = document.getElementById('longitude');
    const accuracyInput = document.getElementById('accuracy');
    const fingerprintInput = document.getElementById('fingerprint');
    const isMobileInput = document.getElementById('is_mobile');
    const ssidInput = document.getElementById('ssid');
    const btnPresent = document.getElementById('btn-present');
    const faceContainer = document.getElementById('face-liveness-container');
    const livenessStatus = document.getElementById('liveness-status');
    const video = document.getElementById('video');

    // State
    let isFingerprintReady = false;
    let isLivenessVerified = false;
    let gpsWatchId = null;
    let gpsLastUpdateTime = 0;
    let currentWorkType = 'WFO';

    // Debug Logger
    function logToUI(msg, type = 'info') {
        const debugContent = document.getElementById('debug-content');
        if (!debugContent) return;
        const color = type === 'error' ? '#ff6b6b' : (type === 'success' ? '#51cf66' : '#ffffff');
        const time = new Date().toLocaleTimeString();
        debugContent.innerHTML += `<div style="font-size:9px; color: ${color}">[${time}] ${msg}</div>`;
        debugContent.scrollTop = debugContent.scrollHeight;
        console.log(`[Presence] ${msg}`);
    }

    // 1. Initialize FingerprintJS
    async function initFingerprint() {
        logToUI("Loading FingerprintJS...");
        try {
            if (typeof FingerprintJS === 'undefined') {
                logToUI("FingerprintJS library not loaded!", 'error');
                return;
            }
            const fp = await FingerprintJS.load();
            const result = await fp.get();
            fingerprintInput.value = result.visitorId;
            logToUI(`Fingerprint Ready: ${result.visitorId}`, 'success');
            
            const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
            isMobileInput.value = isMobile ? '1' : '0';
            logToUI(`Device: ${isMobile ? 'Mobile' : 'Desktop'}`);
            
            isFingerprintReady = true;
            checkReadyState();
        } catch (err) {
            logToUI(`FingerprintJS Error: ${err.message}`, 'error');
        }
    }

    // 2. Face Liveness Detection (WFO only)
    async function initFaceLiveness() {
        logToUI("Initializing Face AI...");
        faceContainer.style.display = 'block';
        livenessStatus.innerHTML = '<span class="badge bg-warning">Memuat AI Model...</span>';
        
        try {
            if (typeof faceapi === 'undefined') {
                logToUI("face-api.js library not loaded!", 'error');
                return;
            }
            const MODEL_URL = '{{ asset('vendor/face-api/weights') }}';
            await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
            logToUI("Face AI Models Loaded", 'success');
            
            logToUI("Requesting Camera Access...");
            const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" } });
            video.srcObject = stream;
            
            livenessStatus.innerHTML = '<span class="badge bg-info">Menunggu pergerakan wajah...</span>';
            
            video.onplay = () => {
                logToUI("Camera Stream Active");
                let detectionCount = 0;
                const interval = setInterval(async () => {
                    const detections = await faceapi.detectAllFaces(video, new faceapi.TinyFaceDetectorOptions());
                    if (detections.length > 0) {
                        detectionCount++;
                        if (detectionCount % 5 === 0) logToUI(`Face detected (${detectionCount}/10)...`);
                        if (detectionCount >= 10) { 
                            isLivenessVerified = true;
                            livenessStatus.innerHTML = '<span class="badge bg-success">✓ Identitas Wajah Terverifikasi</span>';
                            logToUI("Face Liveness Verified", 'success');
                            clearInterval(interval);
                            checkReadyState();
                        }
                    }
                }, 500);
            };
        } catch (err) {
            logToUI(`Face AI Error: ${err.message}`, 'error');
            livenessStatus.innerHTML = '<span class="badge bg-danger">Kamera gagal / AI error.</span>';
        }
    }

    // 3. Check Ready State - CORE LOGIC
    function checkReadyState() {
        currentWorkType = Array.from(workTypeRadios).find(r => r.checked)?.value || 'WFO';
        const isWFO = currentWorkType === 'WFO';
        
        logToUI(`checkReadyState: mode=${currentWorkType}, FP=${isFingerprintReady}`);
        
        updateCheckItem('check-fingerprint', isFingerprintReady);
        
        if (isWFO) {
            // WFO Mode: 4 validations
            document.getElementById('wfo-checks').style.display = 'block';
            
            const lat = parseFloat(latitudeInput.value);
            const lon = parseFloat(longitudeInput.value);
            let isLocationOK = false;
            
            const locationAlert = document.getElementById('location-warning');
            
            if (!isNaN(lat) && !isNaN(lon)) {
                const distDegrees = Math.sqrt(Math.pow(lat - officeLat, 2) + Math.pow(lon - officeLon, 2));
                const distMeters = Math.round(distDegrees * 111320);
                
                const distDisplay = document.getElementById('distance-display');
                if (distDisplay) distDisplay.value = distMeters;
                
                if (locationAlert) locationAlert.classList.add('d-none');
                
                if (distMeters <= thresholdMeters) {
                    isLocationOK = true;
                    logToUI(`Location OK: ${distMeters}m from office`, 'success');
                } else {
                    logToUI(`Location: Outside radius (${distMeters}m > ${thresholdMeters}m)`, 'error');
                }
            } else {
                if (locationAlert) {
                    locationAlert.classList.remove('d-none');
                    const timeSinceUpdate = Date.now() - gpsLastUpdateTime;
                    if (timeSinceUpdate < 3000) {
                        locationAlert.innerHTML = '<b>⏳ GPS AKTIF</b> : Sedang mencari sinyal satelit... Tunggu beberapa detik.';
                    } else {
                        locationAlert.innerHTML = '<b>⚠️ GPS BELUM TERBACA</b> : Pastikan izin lokasi diaktifkan & GPS mode <b>High Accuracy</b>. Keluar ke area terbuka jika perlu.';
                    }
                }
            }
            
            updateCheckItem('check-location', isLocationOK);
            
            const currentSSID = ssidInput.value.trim();
            const isWiFiOK = allowedSSIDs.includes(currentSSID);
            updateCheckItem('check-wifi', isWiFiOK);
            
            updateCheckItem('check-face', isLivenessVerified);
            
            const allConditionsMet = isFingerprintReady && isLocationOK && isWiFiOK && isLivenessVerified;
            
            logToUI(`WFO Check: FP=${isFingerprintReady}, Loc=${isLocationOK}, WiFi=${isWiFiOK}, Face=${isLivenessVerified} => ${allConditionsMet ? 'READY' : 'NOT READY'}`);
            
            btnPresent.disabled = !allConditionsMet;
        } else {
            // WFH/WFA Mode: ONLY Fingerprint
            document.getElementById('wfo-checks').style.display = 'none';
            
            logToUI(`${currentWorkType} Check: FP=${isFingerprintReady} => ${isFingerprintReady ? 'READY' : 'NOT READY'}`);
            
            // CRITICAL: Enable button if fingerprint ready
            btnPresent.disabled = !isFingerprintReady;
            
            if (isFingerprintReady) {
                logToUI(`✅ Button ENABLED for ${currentWorkType}`, 'success');
            }
        }
    }

    function updateCheckItem(id, isSuccess) {
        const el = document.getElementById(id);
        if (!el) return;
        const icon = el.querySelector('i');
        if (isSuccess) {
            el.classList.add('text-success');
            el.classList.remove('text-muted');
            icon.className = 'bi bi-check-circle-fill text-success';
        } else {
            el.classList.remove('text-success');
            icon.className = 'bi bi-clock text-warning';
        }
    }

    // 4. GPS Functions (WFO only)
    function startAggressiveGPS() {
        logToUI("🚀 Starting GPS tracking...");
        
        if (typeof window !== 'undefined' && window.isSecureContext === false) {
            logToUI('🔒 GPS BLOCKED: Site must use HTTPS', 'error');
            alert('⚠️ GPS hanya bekerja di HTTPS. Hubungi IT untuk mengaktifkan SSL.');
            return;
        }

        if (!navigator.geolocation) {
            logToUI('❌ Geolocation not supported', 'error');
            return;
        }

        const onSuccess = (position) => {
            gpsLastUpdateTime = Date.now();
            const lat = position.coords.latitude;
            const lon = position.coords.longitude;
            const acc = position.coords.accuracy;
            
            logToUI(`📍 GPS: ${lat.toFixed(6)}, ${lon.toFixed(6)} (±${Math.round(acc)}m)`, 'success');

            latitudeInput.value = lat;
            longitudeInput.value = lon;
            accuracyInput.value = acc;

            if (acc <= 1) {
                logToUI('⚠️ SUSPICIOUS: Perfect accuracy detected', 'error');
                alert('⚠️ Akurasi GPS mencurigakan. Jangan gunakan Fake GPS!');
            }

            checkReadyState();
        };

        const onError = (error) => {
            let msg = '❌ GPS Error: ';
            switch (error.code) {
                case error.PERMISSION_DENIED:
                    msg += 'Izin ditolak. Aktifkan di Settings → Site Permissions → Location';
                    break;
                case error.POSITION_UNAVAILABLE:
                    msg += 'Sinyal tidak tersedia. Aktifkan GPS mode High Accuracy';
                    break;
                case error.TIMEOUT:
                    msg += 'Timeout. Pindah ke area terbuka';
                    break;
                default:
                    msg += 'Unknown error';
                    break;
            }
            logToUI(msg, 'error');
        };

        if (gpsWatchId !== null) {
            navigator.geolocation.clearWatch(gpsWatchId);
        }

        try {
            gpsWatchId = navigator.geolocation.watchPosition(
                onSuccess,
                onError,
                {
                    enableHighAccuracy: true,
                    timeout: 45000,
                    maximumAge: 5000
                }
            );
            logToUI(`📡 GPS Watch started (ID: ${gpsWatchId})`, 'success');
        } catch (e) {
            logToUI(`Exception: ${e.message}`, 'error');
        }
    }

    function stopGPS() {
        if (gpsWatchId !== null) {
            navigator.geolocation.clearWatch(gpsWatchId);
            logToUI(`🛑 GPS Watch stopped (ID: ${gpsWatchId})`);
            gpsWatchId = null;
        }
    }

    function getGPSLocation() {
        logToUI('🔄 Manual GPS refresh');
        navigator.geolocation.getCurrentPosition(
            (pos) => logToUI('Manual GPS OK: ' + pos.coords.latitude),
            (err) => logToUI('Manual GPS failed: ' + err.message, 'error'),
            { enableHighAccuracy: true, timeout: 30000, maximumAge: 0 }
        );
    }

    // 5. Work Type Change Handler
    workTypeRadios.forEach(radio => {
        radio.addEventListener('change', function() {
            const isWFO = this.value === 'WFO';
            currentWorkType = this.value;
            
            logToUI(`Mode changed to: ${this.value}`);
            
            if (isWFO) {
                // Switch to WFO
                gpsSection.style.display = 'block';
                
                // Enable GPS fields
                latitudeInput.setAttribute('name', 'latitude');
                longitudeInput.setAttribute('name', 'longitude');
                accuracyInput.setAttribute('name', 'accuracy');
                ssidInput.setAttribute('name', 'ssid');
                
                startAggressiveGPS();
                
                if (!isLivenessVerified) {
                    initFaceLiveness();
                }
            } else {
                // Switch to WFH/WFA
                gpsSection.style.display = 'none';
                
                stopGPS();
                
                // Stop camera
                if (video.srcObject) {
                    video.srcObject.getTracks().forEach(track => track.stop());
                    video.srcObject = null;
                }
                
                faceContainer.style.display = 'none';
                isLivenessVerified = false;
                
                // CRITICAL: Clear GPS values
                latitudeInput.value = '';
                longitudeInput.value = '';
                accuracyInput.value = '';
                ssidInput.value = '';
                
                // CRITICAL: Remove name attributes (won't be submitted)
                latitudeInput.removeAttribute('name');
                longitudeInput.removeAttribute('name');
                accuracyInput.removeAttribute('name');
                ssidInput.removeAttribute('name');
                
                const locationAlert = document.getElementById('location-warning');
                if (locationAlert) locationAlert.classList.add('d-none');
                
                logToUI(`${this.value}: GPS & Camera stopped, fields cleared`);
            }
            
            // Re-check state
            checkReadyState();
        });
    });

    ssidInput.addEventListener('change', checkReadyState);

    // 6. Form Submit Handler - CRITICAL
    const presenceForm = document.getElementById('presence-form');
    if (presenceForm) {
        presenceForm.addEventListener('submit', function(e) {
            const workType = Array.from(workTypeRadios).find(r => r.checked)?.value;
            const isWFO = workType === 'WFO';
            
            logToUI(`📤 Submitting form for ${workType}...`, 'info');
            
            if (!isWFO) {
                // CRITICAL: For WFH/WFA, FORCE remove GPS fields
                latitudeInput.removeAttribute('name');
                longitudeInput.removeAttribute('name');
                accuracyInput.removeAttribute('name');
                ssidInput.removeAttribute('name');
                
                // Also disable them
                latitudeInput.disabled = true;
                longitudeInput.disabled = true;
                accuracyInput.disabled = true;
                ssidInput.disabled = true;
                
                logToUI(`✅ ${workType}: GPS fields removed from submission`, 'success');
            } else {
                // WFO: Ensure GPS fields are enabled
                latitudeInput.setAttribute('name', 'latitude');
                longitudeInput.setAttribute('name', 'longitude');
                accuracyInput.setAttribute('name', 'accuracy');
                ssidInput.setAttribute('name', 'ssid');
                
                latitudeInput.disabled = false;
                longitudeInput.disabled = false;
                accuracyInput.disabled = false;
                ssidInput.disabled = false;
                
                logToUI('✅ WFO: GPS fields enabled for submission', 'success');
            }
        });
    }

    // 7. INITIALIZE ON LOAD
    document.addEventListener('DOMContentLoaded', () => {
        logToUI("🚀 System initialized");
        
        initFingerprint();
        
        const selectedWorkType = Array.from(workTypeRadios).find(r => r.checked)?.value || 'WFO';
        currentWorkType = selectedWorkType;
        
        if (selectedWorkType === 'WFO') {
            // WFO Mode
            gpsSection.style.display = 'block';
            logToUI("WFO Mode: Starting GPS + Face");
            
            latitudeInput.setAttribute('name', 'latitude');
            longitudeInput.setAttribute('name', 'longitude');
            accuracyInput.setAttribute('name', 'accuracy');
            ssidInput.setAttribute('name', 'ssid');
            
            startAggressiveGPS();
            initFaceLiveness();
        } else {
            // WFH/WFA Mode
            gpsSection.style.display = 'none';
            faceContainer.style.display = 'none';
            logToUI(`${selectedWorkType} Mode: Fingerprint only`);
            
            // Remove GPS fields
            latitudeInput.removeAttribute('name');
            longitudeInput.removeAttribute('name');
            accuracyInput.removeAttribute('name');
            ssidInput.removeAttribute('name');
            
            const locationAlert = document.getElementById('location-warning');
            if (locationAlert) locationAlert.classList.add('d-none');
            
            // Force check after fingerprint loads
            setTimeout(() => {
                checkReadyState();
                logToUI(`Rechecking state for ${selectedWorkType}...`);
            }, 1000);
        }
    });
</script>

@endsection