                                    <span>Identitas Perangkat (Fingerprint)</span>
                                    <i class="bi bi-clock text-warning"></i>
                                </li>
                                <div id="wfo-checks">
                                    <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent px-0 py-1" id="check-location">
                                        <span>Lokasi GPS (Akurasi & Radius)</span>
                                        <i class="bi bi-clock text-warning"></i>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent px-0 py-1" id="check-wifi">
                                        <span>Koneksi WiFi Kantor (SSID)</span>
                                        <i class="bi bi-clock text-warning"></i>
                                    </li>
                                    <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent px-0 py-1" id="check-face">
                                        <span>Verifikasi Wajah (Liveness)</span>
